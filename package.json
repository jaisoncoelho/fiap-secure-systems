{
  "name": "fiap-secure-systems",
  "version": "0.1.0",
  "description": "FIAP Pos Tech Hackathon - Architecture Diagram Analyzer",
  "private": true,
  "scripts": {
    "build": "nest build",
    "build:api-gateway": "nest build api-gateway",
    "build:upload-service": "nest build upload-service",
    "build:processing-service": "nest build processing-service",
    "build:report-service": "nest build report-service",
    "format": "prettier --write \"apps/**/*.ts\" \"libs/**/*.ts\"",
    "start": "nest start",
    "start:api-gateway": "nest start api-gateway --watch",
    "start:upload-service": "nest start upload-service --watch",
    "start:processing-service": "nest start processing-service --watch",
    "start:report-service": "nest start report-service --watch",
    "start:prod:api-gateway": "node dist/apps/api-gateway/apps/api-gateway/src/main.js",
    "start:prod:upload-service": "node dist/apps/upload-service/apps/upload-service/src/main.js",
    "start:prod:processing-service": "node dist/apps/processing-service/apps/processing-service/src/main.js",
    "start:prod:report-service": "node dist/apps/report-service/apps/report-service/src/main.js",
    "lint": "eslint \"{apps,libs}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:e2e": "jest --config ./test/e2e/jest-e2e.config.js --runInBand"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.0",
    "@nestjs/config": "^3.2.3",
    "@nestjs/core": "^10.4.0",
    "@nestjs/microservices": "^10.4.0",
    "@nestjs/platform-express": "^10.4.0",
    "@nestjs/swagger": "^7.4.2",
    "@nestjs/typeorm": "^10.0.2",
    "amqp-connection-manager": "^4.1.14",
    "amqplib": "^0.10.4",
    "axios": "^1.7.7",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "form-data": "^4.0.1",
    "nestjs-pino": "^4.1.0",
    "openai": "^4.65.0",
    "pdf2pic": "^3.1.3",
    "pg": "^8.13.0",
    "pino-http": "^10.3.0",
    "pino-pretty": "^11.2.2",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "sharp": "^0.33.5",
    "typeorm": "^0.3.20",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.5",
    "@nestjs/schematics": "^10.1.4",
    "@nestjs/testing": "^10.4.0",
    "@testcontainers/postgresql": "^11.14.0",
    "@testcontainers/rabbitmq": "^11.14.0",
    "@types/amqplib": "^0.10.8",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.13",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.7.0",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^6.0.2",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.7.0",
    "@typescript-eslint/parser": "^8.7.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.1",
    "jest": "^29.7.0",
    "prettier": "^3.3.3",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "testcontainers": "^11.14.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.6.2"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": ".",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "./coverage",
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/apps/",
      "<rootDir>/libs/"
    ],
    "moduleNameMapper": {
      "^@app/shared(|/.*)$": "<rootDir>/libs/shared/src/$1"
    },
    "setupFiles": [
      "<rootDir>/jest.setup.ts"
    ]
  }
}
