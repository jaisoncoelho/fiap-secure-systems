# API Gateway
API_GATEWAY_PORT=3000
API_KEY=changeme-dev-api-key

# Internal services
UPLOAD_SERVICE_URL=http://upload-service:3001
REPORT_SERVICE_URL=http://report-service:3003

# Service ports
UPLOAD_SERVICE_PORT=3001
PROCESSING_SERVICE_PORT=3002
REPORT_SERVICE_PORT=3003

# PostgreSQL
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=fiap
POSTGRES_PASSWORD=fiap
POSTGRES_DB_UPLOAD=fiap_upload
POSTGRES_DB_PROCESSING=fiap_processing
POSTGRES_DB_REPORT=fiap_report

# RabbitMQ
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=fiap
RABBITMQ_PASSWORD=fiap
RABBITMQ_URL=amqp://fiap:fiap@rabbitmq:5672

# Storage
UPLOAD_DIR=/app/uploads

# OpenAI
OPENAI_API_KEY=sk-replace-me
OPENAI_MODEL=gpt-4o
OPENAI_TIMEOUT_MS=60000
OPENAI_MAX_RETRIES=2

# Logging
LOG_LEVEL=info
